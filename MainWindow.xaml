<Window x:Class="CybersecurityChatbotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Chatbot" 
        Height="700" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="140"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ASCII ART - SIMPLIFIED AND GUARANTEED TO SHOW -->
        <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="5" Margin="0,0,0,5">
            <TextBlock FontFamily="Consolas" 
                       FontSize="10" 
                       Foreground="LimeGreen"
                       TextAlignment="Center"
                       Margin="0,5">
                <Run Text="╔════════════════════════════════════════════════════════════════╗" />
                <LineBreak/>
                <Run Text="║     ██████╗██╗   ██╗██████╗ ███████╗██████╗                     ║" />
                <LineBreak/>
                <Run Text="║    ██╔════╝╚██╗ ██╔╝██╔══██╗██╔════╝██╔══██╗                    ║" />
                <LineBreak/>
                <Run Text="║    ██║      ╚████╔╝ ██████╔╝█████╗  ██████╔╝                    ║" />
                <LineBreak/>
                <Run Text="║    ██║       ╚██╔╝  ██╔══██╗██╔══╝  ██╔══██╗                    ║" />
                <LineBreak/>
                <Run Text="║    ╚██████╗   ██║   ██████╔╝███████╗██║  ██║                    ║" />
                <LineBreak/>
                <Run Text="║     ╚═════╝   ╚═╝   ╚═════╝ ╚══════╝╚═╝  ╚═╝                    ║" />
                <LineBreak/>
                <Run Text="║              CYBERSECURITY AWARENESS CHATBOT                     ║" />
                <LineBreak/>
                <Run Text="╚════════════════════════════════════════════════════════════════╝" />
            </TextBlock>
        </Border>

        <!-- WELCOME LABEL -->
        <Label Grid.Row="1" 
               Content="Welcome to your Cybersecurity Assistant!"
               FontSize="16" FontWeight="Bold"
               Foreground="#FFD700"
               HorizontalAlignment="Center"
               Margin="0,5,0,15"/>

        <!-- CHAT DISPLAY AREA - THIS WILL NOW BE VISIBLE -->
        <Border Grid.Row="2" Background="#2D2D2D" CornerRadius="8" BorderBrush="#404040" BorderThickness="1" Margin="0,5">
            <ScrollViewer x:Name="scrollChat">
                <RichTextBox x:Name="rtxtChat" 
                             Background="#2D2D2D"
                             Foreground="#E0E0E0"
                             FontFamily="Segoe UI"
                             FontSize="13"
                             BorderThickness="0"
                             IsReadOnly="True">
                    <RichTextBox.Resources>
                        <Style TargetType="{x:Type Paragraph}">
                            <Setter Property="Margin" Value="5,2,5,2"/>
                        </Style>
                    </RichTextBox.Resources>
                </RichTextBox>
            </ScrollViewer>
        </Border>

        <!-- INPUT AREA - THIS WILL NOW BE VISIBLE -->
        <Grid Grid.Row="3" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="txtUserInput" 
                     Grid.Column="0"
                     Background="#3D3D3D"
                     Foreground="White"
                     BorderBrush="#555555"
                     BorderThickness="1"
                     Padding="10"
                     FontSize="14"
                     KeyDown="txtUserInput_KeyDown"/>

            <Button x:Name="btnSend" 
                    Grid.Column="1"
                    Content="Send"
                    Width="80"
                    Margin="10,0,0,0"
                    Background="#007ACC"
                    Foreground="White"
                    FontSize="14"
                    FontWeight="Bold"
                    Click="btnSend_Click"
                    Cursor="Hand"/>
        </Grid>

        <!-- TOPIC BUTTONS -->
        <WrapPanel Grid.Row="4" HorizontalAlignment="Center" Margin="0,5,0,0">
            <Button x:Name="btnPassword" Content="Password Safety" 
                    Margin="5" Padding="15,8"
                    Background="#007ACC" Foreground="White"
                    FontSize="12" FontWeight="Bold"
                    Click="btnPassword_Click" Cursor="Hand"/>

            <Button x:Name="btnPhishing" Content="Phishing" 
                    Margin="5" Padding="15,8"
                    Background="#007ACC" Foreground="White"
                    FontSize="12" FontWeight="Bold"
                    Click="btnPhishing_Click" Cursor="Hand"/>

            <Button x:Name="btnBrowsing" Content="Safe Browsing" 
                    Margin="5" Padding="15,8"
                    Background="#007ACC" Foreground="White"
                    FontSize="12" FontWeight="Bold"
                    Click="btnBrowsing_Click" Cursor="Hand"/>

            <Button x:Name="btnHowAreYou" Content="How are you?" 
                    Margin="5" Padding="15,8"
                    Background="#007ACC" Foreground="White"
                    FontSize="12" FontWeight="Bold"
                    Click="btnHowAreYou_Click" Cursor="Hand"/>

            <Button x:Name="btnPurpose" Content="Your Purpose" 
                    Margin="5" Padding="15,8"
                    Background="#007ACC" Foreground="White"
                    FontSize="12" FontWeight="Bold"
                    Click="btnPurpose_Click" Cursor="Hand"/>

            <Button x:Name="btnHelp" Content="Help" 
                    Margin="5" Padding="15,8"
                    Background="#007ACC" Foreground="White"
                    FontSize="12" FontWeight="Bold"
                    Click="btnHelp_Click" Cursor="Hand"/>

            <Button x:Name="btnExit" Content="Exit" 
                    Margin="5" Padding="15,8"
                    Background="#8B0000" Foreground="White"
                    FontSize="12" FontWeight="Bold"
                    Click="btnExit_Click" Cursor="Hand"/>
        </WrapPanel>
    </Grid>
</Window>